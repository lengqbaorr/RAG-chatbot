APP_NAME="RAG Chatbot"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
APP_ENV="dev"
DEBUG=true
TESSERACT_CMD=
OCR_LANGUAGES="eng"
HTTP_TIMEOUT_SECONDS=20
HTTP_USER_AGENT="rag-chatbot/0.1.0"
DISABLE_STARTUP=false

# Local auth
AUTH_ENABLED=false
AUTH_LOCAL_USERNAME="local"
AUTH_LOCAL_PASSWORD="change-me"
AUTH_SECRET_KEY="replace-with-a-long-random-secret"
AUTH_TOKEN_TTL_MINUTES=1440

# Storage and indexing
CHROMA_PATH="./data/chroma"
CHROMA_COLLECTION="personal_docs_bge_m3_1024"
METADATA_DB_PATH="./data/metadata.db"
UPLOAD_DIR="./data/raw"
MAX_UPLOAD_MB=50
ALLOWED_UPLOAD_EXTENSIONS="pdf,docx,txt,md,png,jpg,jpeg,bmp,gif,tif,tiff,webp"
DUPLICATE_POLICY="skip"

# Embedding
EMBEDDING_PROVIDER="bge-m3"
EMBEDDING_MODEL="BAAI/bge-m3"
EMBEDDING_DIMENSION=1024
EMBEDDING_CACHE_PATH="./data/embeddings.db"
EMBEDDING_LOCAL_FILES_ONLY=true

# Retrieval
DEFAULT_RETRIEVAL_STRATEGY="parent_child"
DEFAULT_TOP_K=3
DEFAULT_FETCH_K=8
DEFAULT_MIN_SCORE=0.70
RETRIEVAL_FALLBACK_ENABLED=true
RETRIEVAL_FALLBACK_MIN_SCORE=0.55
RERANKER_ENABLED=false
RERANKER_MODEL="BAAI/bge-reranker-v2-m3"
RERANKER_DEVICE="cpu"
RERANKER_LOCAL_FILES_ONLY=true

# LLM providers
LLM_PROVIDER="gemini"
LLM_MODEL="gemini-2.5-flash"
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME="RAG Chatbot"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:8b"
