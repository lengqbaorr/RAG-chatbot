# Environment and secrets
.env
.env.*
!.env.example
deploy/docker.env

# Virtualenv and Python cache
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.ruff_cache/

# Local data, uploads, vector DBs, and embedding caches
data/chroma*/
data/*chroma*/
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-journal
data/*.sqlite3-journal
data/raw/*
data/processed/*
data/test_uploads/
data/hf_cache/
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/.gitkeep

# Personal documents should not be pushed by default
*.pdf
*.docx
*.doc
*.pptx
*.xlsx

# Frontend artifacts
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
