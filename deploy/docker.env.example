APP_NAME="RAG Chatbot"
APP_VERSION="0.1.0"
ENVIRONMENT="docker"
APP_ENV="prod"
DEBUG=false
DISABLE_STARTUP=false

# Required for Gemini.
GEMINI_API_KEY= 

# Storage inside the backend container. docker-compose mounts /app/data as a volume.
CHROMA_PATH="/app/data/chroma"
CHROMA_COLLECTION="personal_docs_bge_m3_1024"
METADATA_DB_PATH="/app/data/metadata.db"
EMBEDDING_CACHE_PATH="/app/data/embeddings.db"
UPLOAD_DIR="/app/data/raw"
MAX_UPLOAD_MB=50
ALLOWED_UPLOAD_EXTENSIONS="pdf,docx,txt,md,png,jpg,jpeg,bmp,gif,tif,tiff,webp"
DUPLICATE_POLICY="skip"

# OCR.
TESSERACT_CMD="/usr/bin/tesseract"
OCR_LANGUAGES="eng+vie"

# Embedding.
EMBEDDING_PROVIDER="bge-m3"
EMBEDDING_MODEL="BAAI/bge-m3"
EMBEDDING_DIMENSION=1024
# Set false for the first container run if the model is not cached in the volume yet.
# After the model has downloaded, set true for offline/reproducible startup.
EMBEDDING_LOCAL_FILES_ONLY=false

# Retrieval.
DEFAULT_RETRIEVAL_STRATEGY="parent_child"
DEFAULT_TOP_K=3
DEFAULT_FETCH_K=8
DEFAULT_MIN_SCORE=0.76
RETRIEVAL_FALLBACK_ENABLED=true
RETRIEVAL_FALLBACK_MIN_SCORE=0.55

# Reranker is disabled by default because the model is large and increases latency.
RERANKER_ENABLED=false
RERANKER_MODEL="BAAI/bge-reranker-v2-m3"
RERANKER_DEVICE="cpu"
RERANKER_LOCAL_FILES_ONLY=false

# LLM.
LLM_PROVIDER="gemini"
LLM_MODEL="gemini-2.5-flash"
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# Local auth. Enable only when deploying outside your own machine.
AUTH_ENABLED=false
AUTH_LOCAL_USERNAME="local"
AUTH_LOCAL_PASSWORD="change-me"
AUTH_SECRET_KEY="replace-with-a-long-random-secret"
AUTH_TOKEN_TTL_MINUTES=1440

# Frontend is served from http://127.0.0.1:8080 in docker-compose.
CORS_ORIGINS="http://127.0.0.1:8080,http://localhost:8080"
CORS_ORIGIN_REGEX="http://(localhost|127\.0\.0\.1)(:\d+)?"

HTTP_TIMEOUT_SECONDS=20
HTTP_USER_AGENT="rag-chatbot/0.1.0"
